ANTHROPIC_API_KEY=your_key_here

# Last 3 digits of GoPro serial number (printed on camera body).
# Required because Hero 13 firmware doesn't advertise mDNS.
GOPRO_SERIAL=

# Rsync destination for pushing sentinel logs from roaster to dev machine.
# Format: user@host:/path/to/captures/
SENTINEL_RSYNC_DEST=

# SSH host for deploy.sh (alias from ~/.ssh/config or user@host)
DEPLOY_SSH_HOST=

# Remote directory on roaster (default: ~/CodeProjects/gopro)
# DEPLOY_REMOTE_DIR=~/CodeProjects/gopro
